        "FAIR_VALUES = {}\n",
        "for _, r in results_df.iterrows():\n",
        "    FAIR_VALUES[int(r['stock'])] = (\n",
        "        r['fair_value'], r['uncertainty'])\n",
        "\n",
        "def get_aggression_mode(leaderboard_pos, total_teams=20, bankroll=100000):\n",
        "    top    = max(3, int(0.20 * total_teams))\n",
        "    bottom = max(3, int(0.70 * total_teams))\n",
        "    if bankroll < 30_000:             return 'PROTECT'\n",
        "    if leaderboard_pos <= top:        return 'PROTECT'\n",
        "    elif leaderboard_pos >= bottom:   return 'CATCH_UP'\n",
        "    else:                             return 'BALANCED'\n",
        "\n",
        "def decide_trade(stock_id, mkt_bid, mkt_ask,\n",
        "                 bankroll=100_000, leaderboard_pos=10,\n",
        "                 total_teams=20, min_shares=10):\n",
        "    \"\"\"\n",
        "    Real hackathon mechanics:\n",
        "      - You see a BID/ASK spread from market makers, not a single price\n",
        "      - BUY executes at the ASK (you pay more)\n",
        "      - SELL executes at the BID (you receive less)\n",
        "      - Trade size is in WHOLE SHARES, minimum 10 shares\n",
        "      - ALWAYS returns BUY or SELL (trading is mandatory every round)\n",
        "    \"\"\"\n",
        "    mu, sigma = FAIR_VALUES[stock_id]\n",
        "    rel_sig   = sigma / mu\n",
        "    mid       = round((mkt_bid + mkt_ask) / 2, 2)\n",
        "\n",
        "    # ─── Direction & edge ────────────────────────────────────────────\n",
        "    if mu > mkt_ask:\n",
        "        # Our fair value is ABOVE the ask: BUY at ask, capture full edge\n",
        "        direction  = 'BUY'\n",
        "        exec_price = mkt_ask\n",
        "        edge       = (mu - mkt_ask) / mu\n",
        "        within_spread = False\n",
        "    elif mu < mkt_bid:\n",
        "        # Our fair value is BELOW the bid: SELL at bid, capture full edge\n",
        "        direction  = 'SELL'\n",
        "        exec_price = mkt_bid\n",
        "        edge       = (mkt_bid - mu) / mu\n",
        "        within_spread = False\n",
        "    else:\n",
        "        # Fair value is INSIDE the spread — lean toward the closer side\n",
        "        direction  = 'BUY' if mu >= mid else 'SELL'\n",
        "        exec_price = mkt_ask if direction == 'BUY' else mkt_bid\n",
        "        edge       = 0.0\n",
        "        within_spread = True\n",
        "\n",
        "    snr = edge / (rel_sig + 1e-9)\n",
        "\n",
        "    # ─── Aggression mode ─────────────────────────────────────────────\n",
        "    mode = get_aggression_mode(leaderboard_pos, total_teams, bankroll)\n",
        "    if mode == 'PROTECT':\n",
        "        kelly_mult, max_frac = 0.10, 0.12\n",
        "    elif mode == 'BALANCED':\n",
        "        kelly_mult, max_frac = 0.20, 0.22\n",
        "    else:                                          # CATCH_UP\n",
        "        kelly_mult, max_frac = 0.32, 0.35\n",
        "\n",
        "    # Confidence penalty (higher uncertainty → smaller bet)\n",
        "    unc_pct = 100 * rel_sig\n",
        "    conf_penalty = 1.0\n",
        "    if unc_pct > 12: conf_penalty *= 0.70\n",
        "    if unc_pct > 20: conf_penalty *= 0.55\n",
        "    if unc_pct > 30: conf_penalty *= 0.40\n",
        "\n",
        "    # ─── Size in SHARES ──────────────────────────────────────────────\n",
        "    if within_spread or edge <= 0.5 * rel_sig:\n",
        "        # Weak / no edge: trade the minimum\n",
        "        shares = min_shares\n",
        "        signal = 'WEAK'\n",
        "    else:\n",
        "        kelly_f  = kelly_mult * conf_penalty * snr / (1 + snr)\n",
        "        size_f   = min(kelly_f, max_frac)\n",
        "        max_cost = size_f * bankroll            # £ budget for this trade\n",
        "        raw_shares = int(max_cost / exec_price) # floor to whole shares\n",
        "        shares   = max(min_shares, raw_shares)\n",
        "        signal   = ('A' if edge > 2 * rel_sig\n",
        "                    else 'B' if edge > rel_sig else 'C')\n",
        "\n",
        "    cost = round(shares * exec_price, 2)\n",
        "\n",
        "    spread = round(mkt_ask - mkt_bid, 2)\n",
        "    return {\n",
        "        'action':       direction,\n",
        "        'shares':       shares,\n",
        "        'exec_price':   exec_price,\n",
        "        'total_cost':   cost,\n",
        "        'signal':       signal,\n",
        "        'mode':         mode,\n",
        "        'edge_vs_exec': f'{100*edge:.2f}%',\n",
        "        'within_spread': within_spread,\n",
        "        'reason': (\n",
        "            f'{\"INSIDE SPREAD\" if within_spread else f\"edge={100*edge:.2f}%\"} | '\n",
        "            f'spread={spread:.2f} | SNR={snr:.2f} | '\n",
        "            f'mode={mode} | {shares} shares @ {exec_price:.2f}'\n",
        "        )\n",
        "    }\n",
        "\n",
        "def choose_quote_multiplier(unc_pct, bankroll=100_000):\n",
        "    \"\"\"How wide to quote YOUR OWN bid/ask when acting as market maker.\"\"\"\n",
        "    if unc_pct < 5:    k = 0.35\n",
        "    elif unc_pct < 12: k = 0.80\n",
        "    elif unc_pct < 20: k = 1.40\n",
        "    else:              k = 2.00\n",
        "    if bankroll < 50_000: k *= 1.25\n",
        "    if bankroll < 30_000: k *= 1.35\n",
        "    return k\n",
        "\n",
        "print('Decision engine loaded (bid/ask, share-based sizing).')\n",
        "print()\n",
        "print('Fair values:')\n",
        "for sid, (mu, sig) in FAIR_VALUES.items():\n",
        "    print(f'  Stock {sid}: {mu:.2f}  +/-{sig:.2f}  ({100*sig/mu:.1f}%)')"
      ]
