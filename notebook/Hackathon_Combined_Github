      "source": [
        "def rmse_score(y_true, y_pred):\n",
        "    return float(np.sqrt(mean_squared_error(y_true, y_pred)))\n",
        "\n",
        "def choose_cv(n_rows):\n",
        "    if n_rows < 40:    return 3\n",
        "    elif n_rows < 200: return 5\n",
        "    else:              return 10\n",
        "\n",
        "def build_sklearn_models(n_rows):\n",
        "    models = {\n",
        "        'ridge': Pipeline([('sc', StandardScaler()), ('m', Ridge(alpha=1.0))]),\n",
        "        'elasticnet': Pipeline([('sc', StandardScaler()),\n",
        "                                ('m', ElasticNet(alpha=0.01, l1_ratio=0.2,\n",
        "                                                 random_state=RANDOM_STATE))]),\n",
        "    }\n",
        "    if n_rows >= 500:\n",
        "        models['hgb'] = HistGradientBoostingRegressor(\n",
        "            learning_rate=0.05, max_depth=6, max_iter=250,\n",
        "            random_state=RANDOM_STATE)\n",
        "    if n_rows >= 2000:\n",
        "        models['extratrees'] = ExtraTreesRegressor(\n",
        "            n_estimators=200, max_depth=None, min_samples_leaf=2,\n",
        "            random_state=RANDOM_STATE, n_jobs=-1)\n",
        "    if n_rows >= 200:\n",
        "        models['gbm'] = GradientBoostingRegressor(\n",
        "            n_estimators=300, max_depth=4, learning_rate=0.05,\n",
        "            subsample=0.8, random_state=RANDOM_STATE)\n",
        "    return models\n",
        "\n",
        "print('sklearn model zoo loaded.')"
      ]
