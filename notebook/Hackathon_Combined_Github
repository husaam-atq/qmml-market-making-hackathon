        "    if use_poly:\n",
        "        X_p = add_poly2(X_train)\n",
        "        X_p_te = add_poly2(X_test)\n",
        "        X_p_s, _, _ = standardize(X_p)          # FIX: 3 return values, not 4\n",
        "        Up, sp, Vtp = svd_cache(X_p_s)\n",
        "        a_poly, poly_loo = best_alpha_loo(Up, sp, Vtp, y_train)\n",
        "        if poly_loo >= loo_rmse:\n",
        "            use_poly = False\n",
        "        else:\n",
        "            print(f'  Poly2 improves: {loo_rmse:.3f} -> {poly_loo:.3f}')\n",
        "\n",
        "    # NumPy Ridge prediction\n",
        "    ridge_pred, ridge_std = model_avg_predict(X_train, y_train, X_test, best_a)\n",
        "    if use_poly:\n",
        "        poly_pred, poly_std = model_avg_predict(X_p, y_train, X_p_te, a_poly)\n",
