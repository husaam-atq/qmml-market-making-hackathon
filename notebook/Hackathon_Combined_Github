    {
      "cell_type": "markdown",
      "metadata": {
        "id": "mvaXnc0Gynvd"
      },
      "source": [
        "### What this cell does\n",
        "Defines the **core prediction engine** - a pure-NumPy Ridge regression pipeline. No sklearn needed here, so it works even when network access is blocked.\n",
        "\n",
        "Key functions defined:\n",
        "- `standardize` — zero-mean, unit-variance scaling (fit on train, applied to test)\n",
        "- `add_poly2` — appends all degree-2 interaction terms (e.g. x₁·x₂). Only used when the dataset is large enough to avoid overfitting.\n",
        "- `svd_cache` — decomposes the training matrix X = U·S·Vᵀ once and reuses it across all alpha values (fast)\n",
        "- `ridge_from_svd` — solves Ridge weights analytically from the cached SVD\n",
        "- `exact_loo_from_svd` — computes **exact leave-one-out CV error** using the hat-matrix shortcut (no loops, no approximation)\n",
        "- `best_alpha_loo` — sweeps 60 alpha values and picks the one with lowest LOO RMSE\n",
        "- `predict_ridge_numpy` — standardises, selects best alpha, fits, predicts test set\n",
        "- `model_avg_predict` — averages predictions across a neighbourhood of near-optimal alphas (reduces variance)\n",
        "- `bootstrap_predict_small` — for datasets with fewer than 200 rows, runs 300 bootstrap samples to get a stable prediction and uncertainty estimate\n",
        "\n",
        "**Run once at the start.**"
      ],
      "id": "mvaXnc0Gynvd"
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "step2-ridge",
      "metadata": {
        "id": "step2-ridge",
        "outputId": "e9f057ab-01fb-4af8-913f-d747a86477c4"
      },
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "NumPy Ridge engine loaded.\n"
          ]
        }
      ],
      "source": [
        "ALPHAS = np.logspace(-4, 8, 60)\n",
        "\n",
        "def standardize(X_train, X_test=None):\n",
        "    mu  = X_train.mean(axis=0)\n",
        "    sig = X_train.std(axis=0) + 1e-12\n",
        "    X_s = (X_train - mu) / sig\n",
        "    if X_test is None:\n",
        "        return X_s, mu, sig\n",
        "    return X_s, (X_test - mu) / sig, mu, sig\n",
        "\n",
        "def add_poly2(X):\n",
        "    n, p = X.shape\n",
        "    pairs = list(itertools.combinations_with_replacement(range(p), 2))\n",
        "    extras = np.column_stack([X[:, i] * X[:, j] for i, j in pairs])\n",
        "    return np.hstack([X, extras])\n",
        "\n",
        "def svd_cache(X_s):\n",
        "    return np.linalg.svd(X_s, full_matrices=False)\n",
        "\n",
        "def ridge_from_svd(U, s, Vt, y_c, alpha):\n",
        "    d    = s**2 / (s**2 + alpha)\n",
        "    beta = Vt.T @ ((d / s) * (U.T @ y_c))\n",
        "    return beta, d\n",
        "\n",
        "def exact_loo_from_svd(U, s, Vt, y, alpha):\n",
        "    \"\"\"Exact LOO RMSE via hat-matrix shortcut. O(n*p) per alpha.\"\"\"\n",
        "    y_m = y.mean(); y_c = y - y_m\n",
        "    beta, d = ridge_from_svd(U, s, Vt, y_c, alpha)\n",
        "    y_hat = U @ (d * (U.T @ y_c)) + y_m\n",
        "    res   = y - y_hat\n",
        "    h     = np.clip((U**2) @ d, 0, 0.9999)\n",
        "    loo_e = res / (1 - h)\n",
        "    return float(np.sqrt(np.mean(loo_e**2)))\n",
        "\n",
        "def best_alpha_loo(U, s, Vt, y):\n",
        "    best_a, best_rmse = ALPHAS[0], np.inf\n",
        "    for a in ALPHAS:\n",
        "        rmse_val = exact_loo_from_svd(U, s, Vt, y, a)\n",
        "        if rmse_val < best_rmse:\n",
        "            best_rmse, best_a = rmse_val, a\n",
        "    return best_a, best_rmse\n",
        "\n",
        "def predict_ridge_numpy(X_train, y_train, X_test, alpha):\n",
        "    X_tr_s, X_te_s, _, _ = standardize(X_train, X_test)\n",
        "    y_m = y_train.mean(); y_c = y_train - y_m\n",
        "    U, s, Vt = svd_cache(X_tr_s)\n",
        "    beta, _ = ridge_from_svd(U, s, Vt, y_c, alpha)\n",
        "    result = X_te_s @ beta + y_m\n",
        "    return float(np.ravel(result)[0])\n",
        "\n",
        "def model_avg_predict(X_train, y_train, X_test, best_a, n_neighbours=4):\n",
        "    \"\"\"Average predictions over nearby alphas for variance reduction.\"\"\"\n",
        "    X_tr_s, X_te_s, _, _ = standardize(X_train, X_test)\n",
        "    y_m = y_train.mean(); y_c = y_train - y_m\n",
        "    U, s, Vt = svd_cache(X_tr_s)\n",
        "    preds = []\n",
        "    for r in np.logspace(-0.75, 0.75, 2 * n_neighbours + 1):\n",
        "        a = best_a * r\n",
        "        beta, _ = ridge_from_svd(U, s, Vt, y_c, a)\n",
        "        result = X_te_s @ beta + y_m\n",
        "        preds.append(float(np.ravel(result)[0]))\n",
        "    return float(np.mean(preds)), float(np.std(preds))\n",
        "\n",
        "def bootstrap_predict_small(X_train, y_train, X_test, alpha, n_boot=300, seed=7):\n",
        "    \"\"\"Bootstrap bagging for small datasets (n < 200).\"\"\"\n",
        "    rng = np.random.default_rng(seed)\n",
        "    n = len(y_train)\n",
        "    preds = []\n",
        "    for _ in range(n_boot):\n",
        "        idx = rng.integers(0, n, n)\n",
        "        Xb, yb = X_train[idx], y_train[idx]\n",
        "        if yb.std() < 1e-8:\n",
        "            continue\n",
        "        try:\n",
        "            preds.append(predict_ridge_numpy(Xb, yb, X_test, alpha))\n",
        "        except Exception:\n",
        "            pass\n",
        "    return float(np.median(preds)), float(np.std(preds))\n",
        "\n",
        "print('NumPy Ridge engine loaded.')"
      ]
    },
